# ─────────────────────────────────────────────────────────────────
#  Smart Harvest — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env or serviceAccountKey.json to git.
# ─────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=true

# ── Firebase ─────────────────────────────────────────────────────
# Path to the service account key downloaded from Firebase Console:
#   Firebase Console → Project Settings → Service accounts
#   → Generate new private key
FIREBASE_CREDENTIALS=serviceAccountKey.json
FIREBASE_PROJECT_ID=smart-harvest-f27d4

# ── OpenWeatherMap ───────────────────────────────────────────────
# Free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ── SMTP (Email OTP) ─────────────────────────────────────────────
# Used to send 6-digit verification codes during registration.
#
# Gmail setup (recommended):
#   1. Enable 2-Step Verification on your Google Account.
#   2. Go to: Google Account → Security → App passwords → Generate.
#   3. Use the 16-character app password below (NOT your login password).
#
# Other providers: change SMTP_HOST / SMTP_PORT accordingly.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=your_gmail_address@gmail.com
